# Android Keystore Configuration
# This file is used to sign the release APK

# Path to the keystore file (relative to project root)
# Generate with: keytool -genkey -v -keystore skripzy-release.jks -keyalg RSA -keysize 2048 -validity 10000 -alias skripzy_key
storeFile=skripzy-release.jks

# Password for the keystore
storePassword=YOUR_STORE_PASSWORD_HERE

# Alias of the key within the keystore
keyAlias=skripzy_key

# Password for the key
keyPassword=YOUR_KEY_PASSWORD_HERE
